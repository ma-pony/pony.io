{
  "name": "starter-blog",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD next dev --webpack",
    "workspace:sync": "node ./scripts/sync-workspace.mjs",
    "workspace:build": "npm run workspace:sync && npm run build",
    "content:check": "node ./scripts/check-content.mjs",
    "build": "npm run content:check && contentlayer2 build && cross-env INIT_CWD=$PWD next build --webpack && sed -i'' -e 's/assert { type:/with { type:/g' .contentlayer/generated/index.mjs && cross-env NODE_OPTIONS='--experimental-json-modules' node -r esbuild-register ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir components --dir lib --dir layouts --dir scripts"
  },
  "dependencies": {
    "@next/bundle-analyzer": "13.1.6",
    "@next/font": "13.1.6",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.9",
    "@vercel/analytics": "^1.0.2",
    "autoprefixer": "^10.4.13",
    "contentlayer2": "^0.5.8",
    "esbuild": "^0.28.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.2",
    "image-size": "1.0.0",
    "mdx-bundler": "^9.0.0",
    "next": "^16.2.9",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.2.0",
    "pliny": "^0.2.1",
    "postcss": "^8.5.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "^7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^14.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.2.2",
    "unist-util-visit": "^4.1.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^6.3.1",
    "@types/react": "^18.0.18",
    "@typescript-eslint/eslint-plugin": "^5.36.2",
    "@typescript-eslint/parser": "^5.36.2",
    "cross-env": "^7.0.3",
    "dedent": "^0.7.0",
    "esbuild-register": "3.4.2",
    "eslint": "^8.23.0",
    "eslint-config-next": "13.1.6",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "file-loader": "^6.0.0",
    "globby": "11.0.3",
    "husky": "^8.0.0",
    "js-yaml": "4.1.0",
    "lint-staged": "^13.0.0",
    "prettier": "^2.7.0",
    "prettier-plugin-tailwindcss": "^0.2.2",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "overrides": {
    "esbuild": "$esbuild",
    "postcss": "$postcss",
    "estree-util-value-to-estree": "^3.4.0",
    "uuid": "^11.1.0"
  }
}
